# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# For local dev: the file:// origin or a live-server port
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,null

# SQLite database path (relative to project root)
DB_PATH=./db/radiocom.sqlite

# Rate limiting (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email simulation — set to "true" to log full email payloads
LOG_EMAIL_BODY=true
